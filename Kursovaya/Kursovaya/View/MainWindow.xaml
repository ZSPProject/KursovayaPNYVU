<Window x:Class="Kursovaya.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="To-Do List"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Closing="Window_Closing">

    <Window.Resources>

        <Style TargetType="Button">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style TargetType="TextBox">

            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>

        </Style>

    </Window.Resources>

    <Grid Margin="20">

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- Левая панель -->

        <Border Grid.Column="0"
                Background="White"
                CornerRadius="20"
                Padding="25">

            <StackPanel>

                <TextBlock Text="Управление задачами"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,25"/>

                <!-- Название -->

                <TextBlock Text="Название задачи"
                           FontWeight="SemiBold"/>

                <TextBox Text="{Binding Title}"/>

                <!-- Описание -->

                <TextBlock Text="Описание"
                           FontWeight="SemiBold"/>

                <TextBox Height="50"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding Description}"/>

                <!-- Дата -->

                <TextBlock Text="Срок выполнения"
                           FontWeight="SemiBold"/>

                <DatePicker Margin="0,5,0,15"
                            SelectedDate="{Binding DueDate}"/>

                <!-- Статус -->

                <CheckBox Content="Задача выполнена"
                          Margin="0,0,0,20"
                          FontSize="14"
                          IsChecked="{Binding IsCompleted}"/>

                <!-- Кнопки -->

                <Button Content="Добавить задачу"
                        Height="20"
                        Background="#3B82F6"
                        Command="{Binding AddTaskCommand}"/>

                <Button Content="Редактировать"
                        Height="20"
                        Background="#F59E0B"
                        Command="{Binding UpdateTaskCommand}"/>

                <Button Content="Удалить"
                        Height="20"
                        Background="#EF4444"
                        Command="{Binding DeleteTaskCommand}"/>

                <Button Content="Сохранить"
                        Height="20"
                        Background="#14B8A6"
                        Command="{Binding SaveCommand}"/>

                <!-- Фильтр -->

                <TextBlock Text="Фильтр задач"
                           Margin="0,25,0,5"
                           FontWeight="SemiBold"/>

                <ComboBox Height="20"
                          SelectedValue="{Binding SelectedFilter}"
                          SelectedValuePath="Content">

                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="Выполненные"/>
                    <ComboBoxItem Content="Невыполненные"/>
                    <ComboBoxItem Content="Просроченные"/>

                </ComboBox>

                <!-- Дополнительные кнопки -->

                <Button Content="Сортировать по дате"
                        Height="20"
                        Margin="0,20,0,0"
                        Background="#6366F1"
                        Command="{Binding SortByDateCommand}"/>

                <Button Content="Экспорт в CSV"
                        Height="20"
                        Background="#10B981"
                        Command="{Binding ExportCsvCommand}"/>

            </StackPanel>

        </Border>

        <!-- Правая панель -->

        <Border Grid.Column="2"
                Background="White"
                CornerRadius="20"
                Padding="20">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>

                <TextBlock Text="Список задач"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <ListView Grid.Row="1"
                          BorderThickness="0"
                          Background="Transparent"
                          ItemsSource="{Binding TasksView}"
                          SelectedItem="{Binding SelectedTask}">

                    <ListView.ItemTemplate>

                        <DataTemplate>

                            <Border Background="#F9FAFB"
                                    CornerRadius="15"
                                    Margin="0,0,0,15"
                                    Padding="20">

                                <StackPanel>

                                    <DockPanel>

                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   DockPanel.Dock="Left"/>

                                        <CheckBox IsChecked="{Binding IsCompleted}"
                                                  HorizontalAlignment="Right"/>

                                    </DockPanel>

                                    <TextBlock Text="{Binding Description}"
                                               Margin="0,10,0,10"
                                               TextWrapping="Wrap"
                                               Foreground="#4B5563"/>

                                    <TextBlock>

                                        <Run Text="Срок: "/>

                                        <Run Text="{Binding DueDate,
                                                StringFormat=dd.MM.yyyy}"/>

                                    </TextBlock>

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ListView.ItemTemplate>

                </ListView>

            </Grid>

        </Border>

    </Grid>

</Window>